# Database (MongoDB)
DATABASE_URI=mongodb://localhost:27017/pokeori

# Payload CMS
PAYLOAD_SECRET=replace-with-a-long-random-secret

# Email (Resend)
RESEND_API_KEY=re_replace-with-your-resend-api-key

# Google Gemini (optional, for AI features)
GEMINI_API_KEY=

# Redis (optional when using the local helper)

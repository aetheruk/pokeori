{
  "name": "pokeori",
  "version": "0.0.6",
  "description": "Pokeori field-journal adventure game",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build --webpack",
    "dev": "pkill redis-server || true; concurrently --kill-others -n redis,next -c blue,magenta \"./tools/redis-stable/src/redis-server\" \"cross-env NODE_OPTIONS=--no-deprecation next dev --turbo --experimental-https\"",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev --turbo --experimental-https",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "validate:data": "bun test tests/game-schema.test.ts tests/data-references.test.ts tests/generated-data-integrity.test.ts tests/pokemon-form-exclusions.test.ts tests/requirements-semantics.test.ts tests/source-hygiene.test.ts tests/api-response.test.ts tests/rate-limiter.test.ts tests/endless-milestones.test.ts tests/research-input-validation.test.ts tests/battle-action-validation.test.ts tests/battle-item-effects.test.ts tests/pvp-power-state.test.ts tests/pvp-turn-engine.test.ts tests/pvp-turn-sync.test.ts tests/pve-turn-engine.test.ts tests/dev-game-data-tools.test.ts",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "bun test",
    "test:int": "bun test",
    "test:e2e": "echo \"No e2e tests configured\"",
    "generate:game-data": "bun scripts/generate-game-data.mjs",
    "fetch:tcg": "bun scripts/fetch-tcg-data.mjs",
    "generate:tcg": "bun scripts/generate-tcg-modules.mjs",
    "migrate:user-state": "bun scripts/migrate-user-state-collections.ts",
    "sync:tcg-sprites": "bun scripts/sync-tcg-set-sprites.mjs",
    "fetch:pokemon": "bun scripts/fetch-pokemon-data.mjs",
    "generate:pokemon": "bun scripts/generate-pokemon-modules.mjs",
    "generate:evolutions": "bun scripts/generate-evolutions.mjs",
    "generate:mega-stones": "bun scripts/generate-mega-stones.mjs",
    "sync:pokemon-sprites": "bun scripts/sync-pokemon-sprites.mjs",
    "sync:item-sprites": "bun scripts/sync-item-sprites.mjs",
    "download:sprites": "bun scripts/sync-pokemon-sprites.mjs",
    "generate:data": "bun scripts/generate-data-entries.mjs",
    "generate:quizzes": "bun scripts/generate-quizzes.ts --start=256 --limit=10000",
    "clone:sprites": "bun scripts/sync-pokemon-sprites.mjs --prepare-source-only",
    "moves:assign-recommended-forms": "bun scripts/assign-tm-recommended-form-ids.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@hookform/resolvers": "5.4.0",
    "@payloadcms/db-mongodb": "3.85.1",
    "@payloadcms/email-resend": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@payloadcms/ui": "3.85.1",
    "@radix-ui/react-alert-dialog": "1.1.16",
    "@radix-ui/react-collapsible": "1.1.13",
    "@radix-ui/react-dialog": "1.1.16",
    "@radix-ui/react-dropdown-menu": "2.1.17",
    "@radix-ui/react-label": "2.1.9",
    "@radix-ui/react-progress": "1.1.9",
    "@radix-ui/react-scroll-area": "1.2.11",
    "@radix-ui/react-select": "2.3.0",
    "@radix-ui/react-slot": "1.2.5",
    "@radix-ui/react-tabs": "1.1.14",
    "@radix-ui/react-toggle-group": "1.1.12",
    "@tailwindcss/postcss": "4.3.0",
    "@types/canvas-confetti": "1.9.0",
    "@types/matter-js": "0.20.2",
    "bottleneck": "2.19.5",
    "canvas-confetti": "1.9.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "cross-env": "10.1.0",
    "csv-parse": "6.2.1",
    "dotenv": "17.4.2",
    "embla-carousel-react": "8.6.0",
    "framer-motion": "12.40.0",
    "graphql": "16.14.2",
    "ioredis": "5.11.1",
    "jose": "6.2.3",
    "lucide-react": "1.17.0",
    "matter-js": "0.20.0",
    "motion": "12.40.0",
    "next": "16.2.9",
    "next-themes": "0.4.6",
    "payload": "3.85.1",
    "postcss": "8.5.15",
    "radix-ui": "1.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.78.0",
    "react-icons": "5.6.0",
    "react-intersection-observer": "10.0.3",
    "react-starfield": "1.0.3",
    "react-window": "2.2.7",
    "sharp": "0.34.5",
    "simplex-noise": "4.0.3",
    "sonner": "2.0.7",
    "swr": "2.4.1",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "use-sound": "5.0.0",
    "uuid": "13.0.2",
    "vaul": "1.1.2",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@next/bundle-analyzer": "16.2.9",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "baseline-browser-mapping": "2.10.35",
    "concurrently": "10.0.3",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.4",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.13"
  },
  "trustedDependencies": [
    "sharp",
    "esbuild",
    "unrs-resolver"
  ],
  "private": false,
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "overrides": {
    "dompurify": "3.4.9",
    "ws": "8.21.0",
    "postcss": "8.5.15",
    "esbuild": "0.28.0"
  }
}
